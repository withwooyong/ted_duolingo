{
  "name": "ted-duolingo",
  "version": "0.1.0",
  "private": true,
  "description": "Duolingo 스타일 게임화 다국어 학습 앱 (모바일 퍼스트)",
  "scripts": {
    "mobile": "pnpm --filter mobile start",
    "admin": "pnpm --filter admin dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @ted/db generate",
    "db:migrate": "pnpm --filter @ted/db migrate",
    "db:seed": "pnpm --filter @ted/db seed"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.15.0"
}
